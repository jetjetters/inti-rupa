# ============================================
# Cloud App — Environment Variables
# ============================================
# Copy file ini ke .env dan isi dengan nilai yang sesuai
# JANGAN commit file .env ke repository!

# ---- GENERAL ----
ENVIRONMENT=development          # development | production

# ---- AUTH SERVICE ----
AUTH_DB_URL=postgresql://postgres:postgres@auth-db:5432/auth_db
SECRET_KEY=your-secret-key-here-min-32-chars-long
TOKEN_EXPIRE_MINUTES=30

# ---- AI/ITEM SERVICE ----
ITEM_DB_URL=postgresql://postgres:postgres@item-db:5432/item_db
AUTH_SERVICE_URL=http://auth-service:8001

# ---- DATABASE ----
POSTGRES_PASSWORD=postgres

# ---- FRONTEND ----
VITE_API_URL=http://localhost

# ---- LOGGING ----
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# ---- SERVICE NAMES ----
AUTH_SERVICE_NAME=auth-service
ITEM_SERVICE_NAME=ai-service
