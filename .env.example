# ==============================================================================
# Cloud App — Environment Variables Example
# Proyek Inti Rupa Cloud App
# ==============================================================================
# Copy file ini ke .env dan isi dengan nilai yang sesuai sebelum menjalankan docker-compose!
# JANGAN PERNAH commit file .env ke repository Git Anda!

# ---- GENERAL ----
# development | production
ENVIRONMENT=development
# CORS origins yang diizinkan (pisahkan dengan koma)
ALLOWED_ORIGINS=http://localhost,http://localhost:5173

# ---- DATABASE ----
# Gunakan postgresql://<user>:<password>@<host>:<port>/<dbname>
# Note: Di Docker Compose, host database disesuaikan dengan nama service db masing-masing.
DATABASE_URL=postgresql://postgres:postgres@ai-db:5432/ai_db
POSTGRES_PASSWORD=postgres

# ---- SECURITY & JWT AUTH ----
# Secret key untuk sign JWT token (gunakan minimal 32 karakter acak yang kuat)
SECRET_KEY=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET_KEY_MIN_32_CHARS
# Algoritma enkripsi JWT token (contoh: HS256)
ALGORITHM=HS256
# Masa berlaku token (dalam menit)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ---- AI MODEL PROVIDERS KEYS ----
# Hugging Face API key untuk model FLUX/Diffusion (jika digunakan)
HUGGINGFACE_API_KEY=hf_your_huggingface_api_token_here
# Google Gemini API key untuk summarization & OCR
GEMINI_API_KEY=AIzaSy_your_gemini_api_key_here

# ---- FRONTEND ----
# URL gateway / backend endpoint untuk diakses frontend
VITE_API_URL=http://localhost

# ---- LOGGING ----
# Tingkat logging detail: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
